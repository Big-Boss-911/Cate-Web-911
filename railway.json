{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "dockerfile": "source/web_service/Dockerfile"
  },
  "deploy": {
    "startCommand": "bash /app/entrypoint.sh",
    "restartPolicyMaxRetries": 3,
    "healthchecks": {
      "web": "http://localhost:8000/health"
    }
  }
}
